# ---------- Supabase ----------
PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
PUBLIC_SUPABASE_ANON_KEY="your-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"   # server-only, never expose

# ---------- Mollie ----------
MOLLIE_API_KEY="test_xxxx"                          # test_ or live_

# ---------- Site ----------
# Go-live: zet dit op https://villa-happ.nl — canonical, sitemap, robots,
# og-tags en de noindex-guard volgen automatisch (src/lib/site.ts).
# Op *.vercel.app blijft de site bewust op noindex staan.
PUBLIC_SITE_URL="http://localhost:4321"             # ook voor redirect/webhook URLs

# ---------- Mail (optioneel, orderbevestiging via Resend) ----------
# Zonder RESEND_API_KEY wordt er bewust geen mail verstuurd.
RESEND_API_KEY=""                                   # begint met re_
MAIL_FROM="Villa Happ <bestellingen@villa-happ.nl>"

# ---------- Beheer ----------
# CRON_SECRET: beveiligt /api/notify/run (back-in-stock-verzender).
# Vercel stuurt dit automatisch mee als Authorization-header bij cron-runs.
CRON_SECRET=""
# ADMIN_API_SECRET: beveiligt /api/admin/ship (verzendbevestiging + track & trace).
ADMIN_API_SECRET=""
