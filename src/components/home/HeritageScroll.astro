---
// Horizontale pinned timeline, het echte verhaal in zes hoofdstukken.
// Volledige versie staat op /story.
import Pic from '../Pic.astro';
const steps = [
  {
    num: 'Hoofdstuk 01 · Het begin',
    year: '1960',
    title: 'Een moeder, vier kinderen, één winkel',
    text: 'Toni Kuijpers opent Babyparadijs in Tilburg: babykleding, kinderwagens, kinderkamers. Ze staat er alleen voor, met vier jonge kinderen. De jongste is twee weken oud. De winkel blijft open.',
    img: '/img/heritage/origin-babyparadijs.webp',
  },
  {
    num: 'Hoofdstuk 02 · De gok',
    year: '1965',
    title: 'Van zand en grind naar kinderkleding',
    text: 'Noud van Happen ruilt het zand- en grindbedrijf van de familie in voor stof en garen. Met zijn laatste spaarcenten reist hij naar het Verre Oosten om een eigen productielijn op te zetten. Die gok wordt het fundament.',
    img: null,
  },
  {
    num: 'Hoofdstuk 03 · De stille jaren',
    year: "'80s",
    title: 'De marktleider die je niet zag',
    text: 'Van Happen Fashion Groep kleedt een hele generatie, van Wibra en Zeeman tot HEMA en V&D. Grote kans dat je het droeg zonder het te weten. Eigen labels als VHF en Artoni draaien op volle toeren.',
    img: null,
  },
  {
    num: 'Hoofdstuk 04 · Het gezicht',
    year: '1999',
    title: 'Een eigen naam in de Koopgoot',
    text: 'De eerste Villa Happ winkel opent in de Rotterdamse Koopgoot, de tweede in Nijmegen. Het groeit uit tot 80 winkels door Europa, geleid vanuit Kasteel Zwijnsbergen in Brabant, met ambities tot Dubai aan toe.',
    img: '/img/products/hoodie-logo-detail-v2.webp',
  },
  {
    num: 'Hoofdstuk 05 · De val, twee keer',
    year: '2×',
    title: 'The Comeback Kid',
    text: 'Verkocht, gevallen, teruggekocht, opnieuw opgebouwd, opnieuw gevallen. De vakpers gaf Villa Happ in 2007 al een bijnaam: The Comeback Kid. Opstaan zit in het DNA van dit merk.',
    img: null,
  },
  {
    num: 'Hoofdstuk 06 · Nu',
    year: '2024',
    title: 'De derde generatie',
    text: 'Rutger van Happen, kleinzoon van Toni en Noud, haalt in 2021 de merkrechten terug naar de familie. In 2024 keert Villa Happ terug als lifestylelabel. Niet als herhaling van vroeger, maar als hoofdstuk drie. Stap voor stap.',
    img: '/img/products/hoodie-grey-lifestyle-v2.webp',
  },
];
---
<section class="vh-heritage">
  <div class="vh-heritage-track">

    <!-- Intro panel -->
    <div class="vh-heritage-panel vh-heritage-panel--intro">
      <span class="vh-sticker vh-sticker--light" style="--rot: -7deg; top: 20%; right: 14%;">Est. 1960 ✦ Tilburg</span>
      <span class="vh-sticker vh-sticker--light" style="--rot: 4deg; bottom: 18%; left: 12%;">The Comeback Kid · 2007</span>
      <div>
        <p class="vh-heritage-intro-label vh-mono">02 / Het verhaal</p>
        <h2 class="vh-heritage-intro-title">65 jaar, drie generaties, één <span class="vh-italic-accent">verhaal</span></h2>
        <p class="vh-heritage-intro-hint vh-mono"><span class="vh-show-desktop">Scroll om te ontdekken</span><span class="vh-show-mobile">Swipe door de hoofdstukken</span></p>
      </div>
    </div>

    <!-- Timeline panels -->
    {steps.map((step) => (
      <div class="vh-heritage-panel">
        <div class="vh-heritage-text-col">
          <p class="vh-heritage-step-num vh-mono">{step.num}</p>
          <p class="vh-heritage-year">{step.year}</p>
          <h3 class="vh-heritage-step-title">{step.title}</h3>
          <p class="vh-heritage-step-text">{step.text}</p>
        </div>
        <div class={`vh-heritage-media${step.img ? '' : ' vh-heritage-media--placeholder'}`}>
          {step.img
            ? <Pic src={step.img} alt={step.title} width={800} height={600} widths={[480, 640, 768, 1080]} sizes="(max-width: 700px) 90vw, 45vw" loading="lazy" />
            : <span>{step.year}</span>
          }
        </div>
      </div>
    ))}

  </div>
  <div class="vh-heritage-progress"><span></span></div>
</section>
