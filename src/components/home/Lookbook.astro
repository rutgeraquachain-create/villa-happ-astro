---
// Uit het archief — sleepbare 35mm filmstrook met perforatie
import Pic from '../Pic.astro';
const shots = [
  { img: '/img/products/hoodie-grey-lifestyle.webp', id: 'FW26·01' },
  { img: '/img/products/hoodie-blue-lifestyle.webp', id: 'TILBURG BLUE' },
  { img: '/img/products/hoodie-logo-detail.webp', id: 'ARTONI·82' },
  { img: '/img/products/hoodie-grey-back.webp', id: 'HAPP-X·03' },
  { img: '/img/heritage/origin-babyparadijs.webp', id: 'BP·1960' },
  { img: '/img/products/hoodie-blue-front.webp', id: 'KOOPGOOT·99' },
  { img: '/img/products/hoodie-grey-front.webp', id: 'ZWIJNSBERGEN' },
  { img: '/img/products/hoodie-grey-lifestyle-2.webp', id: 'DROP·001' },
];
---
<section class="vh-film-section">
  <div class="vh-film-header vh-reveal">
    <div>
      <p class="vh-film-label vh-mono">05 / Uit het archief</p>
      <h2 class="vh-film-title">Gedragen door <span class="vh-italic-accent">generaties</span></h2>
    </div>
    <p class="vh-film-hint vh-mono">Sleep de strook ↔</p>
  </div>

  <div class="vh-film" data-cursor="Drag">
    <div class="vh-film-track" data-film-track>
      {shots.map((s) => (
        <div class="vh-film-frame">
          <div class="vh-film-shot">
            <Pic src={s.img} alt="" width={400} height={500} widths={[320, 480, 640, 768]} sizes="(max-width: 700px) 240px, 400px" loading="lazy" draggable="false" />
            <span class="vh-film-id vh-mono">{s.id}</span>
          </div>
        </div>
      ))}
      {shots.map((s) => (
        <div class="vh-film-frame" aria-hidden="true">
          <div class="vh-film-shot">
            <Pic src={s.img} alt="" width={400} height={500} widths={[320, 480, 640, 768]} sizes="(max-width: 700px) 240px, 400px" loading="lazy" draggable="false" />
            <span class="vh-film-id vh-mono">{s.id}</span>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
