---
const cells = [
  { img: '/img/products/hoodie-grey-lifestyle.png', caption: 'Heritage FW26', cls: 'vh-lookbook-cell--1' },
  { img: '/img/products/hoodie-blue-lifestyle.png', caption: 'Tilburg Blue', cls: 'vh-lookbook-cell--2' },
  { img: '/img/products/hoodie-logo-detail.png', caption: 'Het detail', cls: 'vh-lookbook-cell--3' },
  { img: '/img/products/hoodie-grey-back.png', caption: 'Back embroidery', cls: 'vh-lookbook-cell--4' },
  { img: '/img/products/hoodie-blue-front.png', caption: 'Studio', cls: 'vh-lookbook-cell--5' },
];
---
<section class="vh-lookbook">
  <div class="vh-lookbook-inner">
    <div class="vh-lookbook-header vh-reveal">
      <p class="vh-lookbook-label vh-mono">07 / Lookbook</p>
      <h2 class="vh-lookbook-title">Gemaakt om <span class="vh-italic-accent">geleefd</span> te worden</h2>
      <p class="vh-lookbook-desc">
        Geen seizoenscollecties die je na een jaar weggooit. Tijdloze stukken,
        gemaakt van premium materialen, ontworpen om mee te gaan.
      </p>
    </div>
    <div class="vh-lookbook-grid">
      {cells.map((c) => (
        <figure class={`vh-lookbook-cell ${c.cls}`}>
          <img src={c.img} alt={c.caption} loading="lazy" />
          <figcaption class="vh-lookbook-caption">{c.caption}</figcaption>
        </figure>
      ))}
    </div>
  </div>
</section>
