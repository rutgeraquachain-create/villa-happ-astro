---
// Campagnemoment — YSL-discipline, Villa Happ warmte.
// Extreem schaalcontrast: full-bleed beeld + piepkleine mono-labels in de
// hoeken + één monumentale Fraunces-regel in het midden. Trage parallax,
// maximale ademruimte, geen ruis. De koele YSL-structuur, het warme palet.
import Pic from '../Pic.astro';
const image = '/img/products/hoodie-blue-lifestyle-v2.webp';
---
<section class="vh-campaign" id="vh-campaign" aria-label="Campagne 2026">
  <div class="vh-campaign-media" data-campaign-media>
    <Pic src={image} alt="Villa Happ campagne 2026, gedragen in de stad" width={1920} height={1280} widths={[768, 1080, 1440, 1920]} sizes="100vw" loading="lazy" data-campaign-img />
    <div class="vh-campaign-scrim" aria-hidden="true"></div>
  </div>

  <div class="vh-campaign-inner">
    <p class="vh-campaign-label vh-mono" data-campaign-label>Campagne 2026 / Tilburg</p>

    <h2 class="vh-campaign-line">
      <span class="vh-line"><span>Niet nieuw.</span></span>
      <span class="vh-line"><span class="vh-italic-accent">Opnieuw.</span></span>
    </h2>

    <p class="vh-campaign-foot vh-mono" data-campaign-foot>Hoofdstuk drie / Villa Happ</p>
  </div>
</section>
