---
// Drop 001 — cinematic takeover (Apple-stijl):
// de echte cap-foto groeit van kaart naar fullscreen terwijl je scrolt,
// tekstlagen bewegen met verschillende snelheden (parallax-diepte).
import { getActiveDrop } from '../../lib/commerce';
import Pic from '../Pic.astro';

const drop = await getActiveDrop();
const d: any = drop || {
  title: 'Villa Happ Back-Cap',
  image_url: '/img/products/back-cap-front-v2.webp',
  slug: 'villa-happ-back-cap',
};
const dropHref = drop ? `/drops/${d.slug}` : `/shop/${d.slug}`;
const image = d.image_url || '/img/products/back-cap-front-v2.webp';
---
<section class="vh-cine" id="vh-cine">
  <div class="vh-cine-stage">

    <!-- Intro-lagen (parallax naar boven uit beeld) -->
    <p class="vh-cine-eyebrow vh-mono" data-cine-intro="1">03 / Drop 001 · Nu live</p>
    <h2 class="vh-cine-title" data-cine-intro="2">
      Villa Happ <span class="vh-italic-accent">Back-Cap</span>
    </h2>

    <!-- Het beeld dat het scherm overneemt -->
    <div class="vh-cine-media" data-cine-media>
      <Pic src={image} alt={d.title} width={900} height={1125} widths={[480, 640, 768, 1080, 1440]} sizes="100vw" loading="lazy" data-cine-img />
      <div class="vh-cine-scrim" data-cine-scrim></div>
    </div>

    <!-- Overlay (verschijnt op fullscreen) -->
    <div class="vh-cine-overlay" data-cine-overlay>
      <p class="vh-mono">Oplage 500 · Genummerd · Certificaat van echtheid</p>
      <h3>Als deze 500 op zijn,<br />komen ze niet terug.</h3>
      <a href={dropHref} class="vh-btn vh-btn--light" data-magnetic>
        <span>Shop Drop 001</span>
        <svg class="vh-btn-arrow" width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
          <path d="M3 8h10m0 0L9 4m4 4L9 12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
        </svg>
      </a>
    </div>

  </div>
</section>
