---
import { getFeaturedProducts, formatPrice } from '../../lib/commerce';
import Pic from '../Pic.astro';
const dbProducts = await getFeaturedProducts(6);
const fallback = [
  { slug: 'organic-cotton-hoodie-olijfgroen', name: 'Organic Cotton Hoodie', price_cents: 5995, image_url: '/img/products/hoodie-grey-front-v2.webp', hover_url: '/img/products/hoodie-grey-back-v2.webp', badge: 'Sale', meta: 'Olijfgroen · Unisex' },
  { slug: 'organic-cotton-hoodie-navy', name: 'Organic Cotton Hoodie', price_cents: 5995, image_url: '/img/products/hoodie-blue-front-v2.webp', hover_url: '/img/products/hoodie-blue-lifestyle-v2.webp', badge: 'Sale', meta: 'Navy · Unisex' },
  { slug: 'villa-happ-back-cap', name: 'Villa Happ Back-Cap', price_cents: 2195, image_url: '/img/products/back-cap-front-v2.webp', hover_url: '/img/products/back-cap-side-v2.webp', badge: 'Limited · 500', meta: 'Drop 001 · One size' },
];
const products = dbProducts.length > 0
  ? dbProducts.map((p) => ({
      slug: p.slug, name: p.name, price_cents: p.price_cents,
      image_url: p.image_url || '/img/products/hoodie-grey-front-v2.webp',
      hover_url: (p.gallery && p.gallery[0]) || p.image_url || '/img/products/hoodie-grey-back-v2.webp',
      badge: p.compare_at_cents ? 'Sale' : (p.featured ? 'Featured' : null),
      meta: p.category || '',
    }))
  : fallback;
---
<section class="vh-shop">
  <div class="vh-shop-inner">
    <div class="vh-shop-header vh-reveal">
      <span class="vh-spin-star" data-spin aria-hidden="true">✱</span>
      <div>
        <p class="vh-shop-label vh-mono">04 / De collectie</p>
        <h2 class="vh-shop-title">Nu te <span class="vh-italic-accent">dragen</span></h2>
      </div>
      <a href="/shop" class="vh-shop-link">
        Bekijk alles
        <svg width="14" height="14" viewBox="0 0 16 16" fill="none" aria-hidden="true">
          <path d="M3 8h10m0 0L9 4m4 4L9 12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
        </svg>
      </a>
    </div>

    <div class="vh-shop-grid">
      {products.map((p, i) => (
        <a href={`/shop/${p.slug}`} class="vh-shop-card vh-reveal" style={`transition-delay:${(i % 3) * 0.1}s`}>
          <div class="vh-shop-card-media">
            <span class="vh-shop-card-num">0{i + 1}</span>
            {p.badge && <span class="vh-shop-card-badge">{p.badge}</span>}
            <Pic src={p.image_url} alt={p.name} class="vh-shop-card-img is-primary" width={600} height={750} widths={[320, 480, 640, 768]} sizes="(max-width: 700px) 90vw, (max-width: 1100px) 45vw, 30vw" loading="lazy" />
            <Pic src={p.hover_url} alt="" class="vh-shop-card-img is-hover" width={600} height={750} widths={[320, 480, 640, 768]} sizes="(max-width: 700px) 90vw, (max-width: 1100px) 45vw, 30vw" loading="lazy" aria-hidden="true" />
            <button class="vh-shop-card-quick" type="button">Bekijk &amp; kies je maat</button>
          </div>
          <div class="vh-shop-card-info">
            <p class="vh-shop-card-name">{p.name}</p>
            <p class="vh-shop-card-price">{formatPrice(p.price_cents)}</p>
          </div>
          {p.meta && <p class="vh-shop-card-meta">{p.meta}</p>}
        </a>
      ))}
    </div>
  </div>
</section>
