---
const brands = ['Patta', 'Daily Paper', 'Olaf', 'Filling Pieces', 'Arte', 'New Amsterdam'];
---
<section class="vh-brands">
  <div class="vh-brands-inner">
    <p class="vh-brands-label vh-mono">08 / H_APProved</p>
    <h2 class="vh-brands-title vh-reveal">Merken die wij dragen, <span class="vh-italic-accent">gecureerd</span> voor jou.</h2>
    <div class="vh-brands-grid vh-reveal">
      {brands.map((b) => <a href="/brands" class="vh-brand-cell">{b}</a>)}
    </div>
  </div>
</section>
