---
// Twee beeldkolommen die tegengesteld driften op scroll,
// met een groot italic woord dat er op een derde snelheid doorheen kruist.
import Pic from '../Pic.astro';
const colA = [
  '/img/products/back-cap-front-v2.webp',
  '/img/products/hoodie-grey-lifestyle-v2.webp',
  '/img/products/hoodie-blue-front-v2.webp',
  '/img/heritage/origin-babyparadijs.webp',
];
const colB = [
  '/img/products/hoodie-blue-lifestyle-v2.webp',
  '/img/products/back-cap-side-v2.webp',
  '/img/products/hoodie-grey-back-v2.webp',
  '/img/products/back-cap-angle-v2.webp',
];
---
<section class="vh-drift" aria-label="Archiefbeelden">
  <div class="vh-drift-word" data-drift-word aria-hidden="true">Stap <span>voor</span> stap</div>
  <div class="vh-drift-cols">
    <div class="vh-drift-col" data-drift="a">
      {colA.map((img) => (
        <figure class="vh-drift-cell"><Pic src={img} alt="" width={600} height={750} widths={[320, 480, 640, 768]} sizes="(max-width: 700px) 50vw, 30vw" loading="lazy" /></figure>
      ))}
    </div>
    <div class="vh-drift-col vh-drift-col--late" data-drift="b">
      {colB.map((img) => (
        <figure class="vh-drift-cell"><Pic src={img} alt="" width={600} height={750} widths={[320, 480, 640, 768]} sizes="(max-width: 700px) 50vw, 30vw" loading="lazy" /></figure>
      ))}
    </div>
  </div>
</section>
