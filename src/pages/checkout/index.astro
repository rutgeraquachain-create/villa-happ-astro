---
export const prerender = true;

import Base from '../../layouts/Base.astro';
import '../../styles/shop.css';
---
<Base title="Afrekenen · Villa Happ" showFooter={false} noindex={true}>
  <section class="vh-page">
    <div class="vh-page-inner">

      <header class="vh-page-head">
        <p class="vh-page-label vh-mono">Afrekenen · Veilig via Mollie</p>
        <h1 class="vh-page-title">Bijna <span class="vh-italic-accent">van jou</span></h1>
      </header>

      <ol class="vh-steps" id="vh-steps" aria-label="Voortgang afrekenen">
        <li class="vh-step is-active" data-step="contact"><span class="vh-step-dot">01</span> Contact</li>
        <li class="vh-step" data-step="address"><span class="vh-step-dot">02</span> Bezorging</li>
        <li class="vh-step" data-step="pay"><span class="vh-step-dot">03</span> Betaling</li>
      </ol>

      <div class="vh-commerce-grid" id="vh-co-grid" hidden>

        <form class="vh-form" id="vh-co-form" novalidate>
          <div class="vh-form-section">
            <h2><i>01</i> Contact</h2>
            <div class="vh-field">
              <label for="co-email">E-mailadres</label>
              <input id="co-email" name="email" type="email" autocomplete="email" required />
            </div>
          </div>

          <div class="vh-form-section">
            <h2><i>02</i> Bezorgadres</h2>
            <div class="vh-form-row">
              <div class="vh-field">
                <label for="co-first">Voornaam</label>
                <input id="co-first" name="first_name" autocomplete="given-name" required />
              </div>
              <div class="vh-field">
                <label for="co-last">Achternaam</label>
                <input id="co-last" name="last_name" autocomplete="family-name" required />
              </div>
            </div>
            <div class="vh-form-row" style="grid-template-columns: 2fr 1fr;">
              <div class="vh-field">
                <label for="co-street">Straat</label>
                <input id="co-street" name="street" autocomplete="address-line1" required />
              </div>
              <div class="vh-field">
                <label for="co-number">Huisnummer</label>
                <input id="co-number" name="house_number" required />
              </div>
            </div>
            <div class="vh-form-row">
              <div class="vh-field">
                <label for="co-postal">Postcode</label>
                <input id="co-postal" name="postal_code" autocomplete="postal-code" required />
              </div>
              <div class="vh-field">
                <label for="co-city">Plaats</label>
                <input id="co-city" name="city" autocomplete="address-level2" required />
              </div>
            </div>
            <div class="vh-field">
              <label for="co-country">Land</label>
              <select id="co-country" name="country">
                <option value="NL" selected>Nederland</option>
                <option value="BE">België</option>
                <option value="DE">Duitsland</option>
              </select>
            </div>
          </div>
        </form>

        <aside class="vh-summary">
          <h2>Jouw bestelling</h2>
          <div class="vh-lines" id="vh-co-lines" style="border-top: 0;"></div>
          <div class="vh-summary-row"><span>Subtotaal</span><span id="vh-co-subtotal"></span></div>
          <div class="vh-summary-row"><span>Verzending</span><span id="vh-co-shipping"></span></div>
          <div class="vh-summary-row total"><span>Totaal</span><b id="vh-co-total"></b></div>

          <div class="vh-demo-note" id="vh-co-demo" hidden>
            <b>Demo-modus.</b> Dit zijn voorbeeldproducten. Koppel Supabase en
            Mollie (echte API-keys in Vercel) om betalingen te activeren.
          </div>
          <div class="vh-error-note" id="vh-co-error" role="alert"></div>

          <button type="submit" form="vh-co-form" class="vh-btn vh-btn--accent" id="vh-co-pay">
            <span id="vh-co-pay-label">Betaal veilig</span>
            <svg class="vh-btn-arrow" width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M3 8h10m0 0L9 4m4 4L9 12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </button>
          <div class="vh-pay-methods" aria-label="Betaalmethoden">
            <span class="vh-pay-chip">iDEAL</span>
            <span class="vh-pay-chip">Bancontact</span>
            <span class="vh-pay-chip">Mastercard</span>
            <span class="vh-pay-chip">VISA</span>
          </div>
          <p class="vh-pay-note">🔒 Versleutelde betaling via Mollie. Je gegevens blijven van jou.</p>
        </aside>
      </div>

      <div class="vh-empty" id="vh-co-empty" hidden>
        <p>Er ligt nog niets in je mandje.</p>
        <a href="/shop" class="vh-btn vh-btn--primary"><span>Ontdek de collectie</span></a>
      </div>

    </div>
  </section>
</Base>

<script>
  import { getCart, cartSubtotal, shippingCostCents, cartHasDemo } from '../../lib/cart';

  const grid = document.getElementById('vh-co-grid')!;
  const empty = document.getElementById('vh-co-empty')!;
  const form = document.getElementById('vh-co-form') as HTMLFormElement;
  const payBtn = document.getElementById('vh-co-pay') as HTMLButtonElement;
  const payLabel = document.getElementById('vh-co-pay-label')!;
  const demoNote = document.getElementById('vh-co-demo')!;
  const errNote = document.getElementById('vh-co-error')!;
  const countrySel = document.getElementById('co-country') as HTMLSelectElement;
  const eur = (c: number) => '€ ' + (c / 100).toFixed(2).replace('.', ',');

  function renderSummary() {
    const items = getCart();
    grid.hidden = items.length === 0;
    empty.hidden = items.length > 0;
    if (!items.length) return;

    document.getElementById('vh-co-lines')!.innerHTML = items.map((i) => `
      <div class="vh-line" style="grid-template-columns: 58px 1fr auto; padding: 14px 0;">
        <img src="${i.image_url || ''}" alt="" style="width: 58px; height: 72px;" />
        <div>
          <p class="vh-line-name" style="font-size: 13px;">${i.name} × ${i.quantity}</p>
          <p class="vh-line-variant">${i.variant_label || ''}</p>
        </div>
        <p class="vh-line-price" style="font-size: 14px;">${eur(i.unit_price_cents * i.quantity)}</p>
      </div>`).join('');

    const subtotal = cartSubtotal();
    const shipping = shippingCostCents(countrySel.value, subtotal);
    document.getElementById('vh-co-subtotal')!.textContent = eur(subtotal);
    document.getElementById('vh-co-shipping')!.textContent = shipping === 0 ? 'Gratis' : eur(shipping);
    document.getElementById('vh-co-total')!.textContent = eur(subtotal + shipping);
    payLabel.textContent = `Betaal ${eur(subtotal + shipping)}`;

    if (cartHasDemo()) {
      demoNote.hidden = false;
      payBtn.disabled = true;
      payLabel.textContent = 'Demo-modus';
    }
  }

  countrySel.addEventListener('change', renderSummary);
  renderSummary();

  /* Stappenindicator (goal-gradient): vult zich terwijl je vordert */
  const stepEls = {
    contact: document.querySelector('[data-step="contact"]') as HTMLElement,
    address: document.querySelector('[data-step="address"]') as HTMLElement,
    pay: document.querySelector('[data-step="pay"]') as HTMLElement,
  };
  const filled = (name: string) => {
    const el = form.querySelector<HTMLInputElement>(`[name="${name}"]`);
    return !!el && !!el.value.trim();
  };
  function updateSteps() {
    const emailEl = form.querySelector<HTMLInputElement>('[name="email"]')!;
    const contactDone = !!emailEl.value.trim() && /.+@.+\..+/.test(emailEl.value);
    const addressDone = ['first_name', 'last_name', 'street', 'house_number', 'postal_code', 'city'].every(filled);
    stepEls.contact.classList.toggle('is-done', contactDone);
    stepEls.contact.classList.toggle('is-active', !contactDone);
    stepEls.address.classList.toggle('is-done', addressDone);
    stepEls.address.classList.toggle('is-active', contactDone && !addressDone);
    stepEls.pay.classList.toggle('is-active', contactDone && addressDone);
  }

  /* Inline validatie (cognitive load + Doherty): per veld op blur */
  const reqInputs = Array.from(form.querySelectorAll<HTMLInputElement>('input[required]'));
  function fieldMsg(input: HTMLInputElement): HTMLElement {
    let m = input.parentElement!.querySelector('.vh-field-msg') as HTMLElement | null;
    if (!m) { m = document.createElement('small'); m.className = 'vh-field-msg'; input.parentElement!.appendChild(m); }
    return m;
  }
  function validateField(input: HTMLInputElement): boolean {
    const v = input.value.trim();
    let ok = !!v;
    if (ok && input.type === 'email') ok = /.+@.+\..+/.test(v);
    input.classList.toggle('is-invalid', !ok);
    input.classList.toggle('is-valid', ok);
    fieldMsg(input).textContent = ok ? '' : (input.type === 'email' ? 'Vul een geldig e-mailadres in' : 'Dit veld is verplicht');
    return ok;
  }
  reqInputs.forEach((input) => {
    input.addEventListener('blur', () => { validateField(input); updateSteps(); });
    input.addEventListener('input', () => { if (input.classList.contains('is-invalid')) validateField(input); updateSteps(); });
  });
  updateSteps();

  /* Formulier bewaren in sessionStorage: refresh, terug-knop of een
     geannuleerde betaling wist niets (frictiereductie) */
  const FORM_KEY = 'vh_checkout_form_v1';
  const formFields = ['email', 'first_name', 'last_name', 'street', 'house_number', 'postal_code', 'city', 'country'];
  const fieldEl = (name: string) => form.querySelector<HTMLInputElement | HTMLSelectElement>(`[name="${name}"]`);
  try {
    const saved = JSON.parse(sessionStorage.getItem(FORM_KEY) || '{}');
    formFields.forEach((name) => {
      const el = fieldEl(name);
      if (el && saved[name] && !el.value) el.value = saved[name];
    });
    updateSteps();
    renderSummary();
  } catch {}
  form.addEventListener('input', () => {
    const data: Record<string, string> = {};
    formFields.forEach((name) => {
      const el = fieldEl(name);
      if (el) data[name] = el.value;
    });
    try { sessionStorage.setItem(FORM_KEY, JSON.stringify(data)); } catch {}
  });

  /* Postcode-autofill via PDOK Locatieserver (gratis, geen key; alleen NL):
     postcode + huisnummer ingevuld = straat en plaats vanzelf goed */
  const pcEl = fieldEl('postal_code') as HTMLInputElement;
  const nrEl = fieldEl('house_number') as HTMLInputElement;
  const streetEl = fieldEl('street') as HTMLInputElement;
  const cityEl = fieldEl('city') as HTMLInputElement;
  let lastLookup = '';
  async function autofillAddress() {
    if (countrySel.value !== 'NL') return;
    const pc = pcEl.value.replace(/\s+/g, '').toUpperCase();
    const nr = parseInt(nrEl.value, 10);
    if (!/^[1-9][0-9]{3}[A-Z]{2}$/.test(pc) || !nr) return;
    const key = `${pc}-${nr}`;
    if (key === lastLookup) return;
    lastLookup = key;
    try {
      const q = `postcode:${pc} and huisnummer:${nr}`;
      const res = await fetch(`https://api.pdok.nl/bzk/locatieserver/search/v3_1/free?q=${encodeURIComponent(q)}&fq=type:adres&rows=1`);
      if (!res.ok) return;
      const json = await res.json();
      const doc = json?.response?.docs?.[0];
      if (!doc?.straatnaam || !doc?.woonplaatsnaam) return;
      streetEl.value = doc.straatnaam;
      cityEl.value = doc.woonplaatsnaam;
      [streetEl, cityEl].forEach((el) => {
        el.classList.remove('is-invalid');
        el.classList.add('is-valid');
        fieldMsg(el).textContent = '';
      });
      form.dispatchEvent(new Event('input'));
      updateSteps();
    } catch { /* stil: handmatig invullen blijft gewoon werken */ }
  }
  pcEl.addEventListener('blur', autofillAddress);
  nrEl.addEventListener('blur', autofillAddress);

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    errNote.classList.remove('is-visible');

    let valid = true;
    reqInputs.forEach((input) => { if (!validateField(input)) valid = false; });
    if (!valid) {
      errNote.textContent = 'Vul de gemarkeerde velden in.';
      errNote.classList.add('is-visible');
      form.querySelector<HTMLInputElement>('.is-invalid')?.focus();
      return;
    }
    if (cartHasDemo()) return;

    const fd = new FormData(form);
    const payload = {
      items: getCart().map((i) => ({ variant_id: i.variant_id, quantity: i.quantity })),
      customer: {
        email: String(fd.get('email')),
        first_name: String(fd.get('first_name')),
        last_name: String(fd.get('last_name')),
      },
      shipping: {
        street: String(fd.get('street')),
        house_number: String(fd.get('house_number')),
        postal_code: String(fd.get('postal_code')),
        city: String(fd.get('city')),
        country: String(fd.get('country')),
      },
    };

    payBtn.disabled = true;
    payLabel.textContent = 'Een moment…';

    try {
      const res = await fetch('/api/checkout/create', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload),
      });
      const data = await res.json();
      if (res.ok && data.checkout_url) {
        window.location.href = data.checkout_url; // → Mollie betaalpagina
      } else {
        errNote.textContent = data.error || 'Afrekenen lukte niet. Probeer het opnieuw.';
        errNote.classList.add('is-visible');
        payBtn.disabled = false;
        renderSummary();
      }
    } catch {
      errNote.textContent = 'Verbinding mislukt. Controleer je internet en probeer opnieuw.';
      errNote.classList.add('is-visible');
      payBtn.disabled = false;
      renderSummary();
    }
  });
</script>
