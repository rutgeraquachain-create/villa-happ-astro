---
export const prerender = true;

import Base from '../../layouts/Base.astro';
import Pic from '../../components/Pic.astro';
import { getCatalog, type CatalogProduct } from '../../lib/catalog';
import { formatPrice } from '../../lib/commerce';
import { optimizedSrc } from '../../lib/img';
import '../../styles/shop.css';

export async function getStaticPaths() {
  const catalog = await getCatalog();
  return catalog.map((product) => ({
    params: { slug: product.slug },
    props: { product, catalog },
  }));
}

interface Props { product: CatalogProduct; catalog: CatalogProduct[]; }
const { product, catalog } = Astro.props;

const related = catalog.filter((p) => p.slug !== product.slug).slice(0, 3);
const totalStock = product.variants.reduce((sum, v) => sum + v.stock, 0);
const soldOut = totalStock === 0;

// Anchoring (Tversky & Kahneman, 1974): toon de echte besparing expliciet
const savingsCents = product.compare_at_cents ? product.compare_at_cents - product.price_cents : 0;
const savingsPct = product.compare_at_cents ? Math.round((savingsCents / product.compare_at_cents) * 100) : 0;

// Echte schaarste + sociaal bewijs uit de werkelijke voorraad (alleen bij oplage)
const edition = product.edition;
const soldOfEdition = edition ? Math.max(0, edition - totalStock) : 0;
const editionPct = edition ? Math.min(100, Math.round((soldOfEdition / edition) * 100)) : 0;

// Maatgids-type afgeleid uit de varianten
const sizeList = product.variants.map((v) => v.size);
const sizeType: 'apparel' | 'socks' | 'onesize' =
  sizeList.some((s) => /^(XS|S|M|L|XL|XXL)$/i.test(s)) ? 'apparel'
  : sizeList.some((s) => s.includes('/')) ? 'socks'
  : 'onesize';

const apparelRows = [
  { size: 'S', len: '168 tot 174', chest: '88 tot 94' },
  { size: 'M', len: '174 tot 180', chest: '94 tot 100' },
  { size: 'L', len: '180 tot 186', chest: '100 tot 106' },
  { size: 'XL', len: '186 tot 192', chest: '106 tot 112' },
  { size: 'XXL', len: '192 tot 198', chest: '112 tot 120' },
];

// SEO: structured data (Product + Breadcrumb + FAQ)
const siteOrigin = Astro.site?.origin || Astro.url.origin;
const productUrl = `${siteOrigin}/shop/${product.slug}`;
const absImages = product.images.map((i) => (i.startsWith('http') ? i : siteOrigin + i));

// Merchant-velden (verzending, retour, prijsgeldigheid) maken het
// aanbod compleet voor Google's productresultaten
const shippingDetailsLd = (['NL', 'BE', 'DE'] as const).map((country) => ({
  '@type': 'OfferShippingDetails',
  shippingRate: {
    '@type': 'MonetaryAmount',
    value: (({ NL: 4.95, BE: 6.95, DE: 8.95 })[country]).toFixed(2),
    currency: 'EUR',
  },
  shippingDestination: { '@type': 'DefinedRegion', addressCountry: country },
  deliveryTime: {
    '@type': 'ShippingDeliveryTime',
    handlingTime: { '@type': 'QuantitativeValue', minValue: 0, maxValue: 1, unitCode: 'DAY' },
    transitTime: { '@type': 'QuantitativeValue', minValue: 1, maxValue: 3, unitCode: 'DAY' },
  },
}));

const priceValidUntil = `${new Date().getFullYear()}-12-31`;

const productLd = {
  '@context': 'https://schema.org',
  '@type': 'Product',
  name: `${product.name} ${product.color}`,
  image: absImages,
  description: product.short_desc,
  sku: product.variants[0]?.sku,
  brand: { '@type': 'Brand', name: 'Villa Happ' },
  offers: {
    '@type': 'Offer',
    url: productUrl,
    priceCurrency: 'EUR',
    price: (product.price_cents / 100).toFixed(2),
    priceValidUntil,
    availability: soldOut ? 'https://schema.org/OutOfStock' : 'https://schema.org/InStock',
    itemCondition: 'https://schema.org/NewCondition',
    shippingDetails: shippingDetailsLd,
    hasMerchantReturnPolicy: {
      '@type': 'MerchantReturnPolicy',
      applicableCountry: ['NL', 'BE', 'DE'],
      returnPolicyCategory: 'https://schema.org/MerchantReturnFiniteReturnWindow',
      merchantReturnDays: 30,
      returnMethod: 'https://schema.org/ReturnByMail',
      returnFees: 'https://schema.org/FreeReturn',
    },
  },
};

const breadcrumbLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: `${siteOrigin}/` },
    { '@type': 'ListItem', position: 2, name: 'Shop', item: `${siteOrigin}/shop` },
    { '@type': 'ListItem', position: 3, name: product.name, item: productUrl },
  ],
};

const sizingAnswer =
  sizeType === 'apparel'
    ? 'Onze stukken vallen ruim en zijn unisex. Twijfel je tussen twee maten, kies dan de kleinere voor een strakkere pasvorm. In de maatgids vind je lengte en borstwijdte per maat.'
    : sizeType === 'socks'
      ? 'Kies je sokmaat op basis van je gewone schoenmaat: 36/41 of 42/46.'
      : 'One size, verstelbaar via de clipsluiting achter. Past comfortabel op een hoofdomtrek van circa 54 tot 61 cm.';

const faqItems = [
  { q: 'Hoe vallen de maten?', a: sizingAnswer },
  { q: 'Wat zijn de levertijd en verzendkosten?', a: 'Voor 16:00 besteld, dezelfde werkdag verzonden via PostNL en meestal de volgende werkdag in huis. Verzending binnen Nederland is gratis vanaf € 75, daaronder € 4,95.' },
  { q: 'Kan ik retourneren?', a: 'Ja, je hebt 30 dagen bedenktijd. Past het niet of bevalt het niet, dan retourneer je kosteloos.' },
  { q: 'Is dit een origineel Villa Happ stuk?', a: edition
      ? `Ja. Dit komt uit een genummerde oplage van ${edition} stuks en wordt geleverd met een certificaat van echtheid.`
      : 'Ja. Elk stuk wordt in Tilburg ontworpen en met zorg gemaakt, in beperkte oplage.' },
];

const faqLd = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqItems.map((f) => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: f.a },
  })),
};

// Data voor het client-script (maatselectie + add-to-cart)
const pdpData = {
  slug: product.slug,
  name: product.name,
  color: product.color,
  price_cents: product.price_cents,
  image: product.images[0],
  variants: product.variants,
  model: product.model || null,
  image_full: optimizedSrc(product.images[0], 1920),
  edition: product.edition || null,
};
---
<Base title={`${product.name} ${product.color} · Villa Happ`} description={product.short_desc} ogImage={product.images[0]}>
  <section class="vh-page">
    <div class="vh-page-inner">

      <nav class="vh-breadcrumb" aria-label="Kruimelpad">
        <a href="/">Home</a> <span aria-hidden="true">/</span>
        <a href="/shop">Shop</a> <span aria-hidden="true">/</span>
        <span class="vh-breadcrumb-current">{product.name}</span>
      </nav>

      <div class="vh-pdp">

        <!-- Gallery -->
        <div class="vh-pdp-gallery">
          <div class={`vh-pdp-main${product.model ? ' show-3d' : ''}`} id="vh-pdp-main">
            <span class="vh-pdp-frame-tag">Archief · {product.variants[0]?.sku?.split('-').slice(0, 2).join('-') || 'VH'}</span>
            <Pic
              src={product.images[0]}
              alt={`${product.name} ${product.color}`}
              id="vh-pdp-mainimg"
              width={900}
              height={1125}
              widths={[480, 640, 768, 1080]}
              sizes="(max-width: 900px) 100vw, 48vw"
              loading="eager"
              fetchpriority="high"
            />
            {product.model && (
              <>
                {/* @ts-ignore — custom element */}
                <model-viewer
                  src={product.model}
                  alt={`${product.name} in 360 graden`}
                  camera-controls
                  auto-rotate
                  auto-rotate-delay="1200"
                  rotation-per-second="22deg"
                  shadow-intensity="0.7"
                  exposure="1.1"
                  environment-image="neutral"
                  camera-orbit="28deg 76deg 108%"
                  min-camera-orbit="auto 50deg 80%"
                  max-camera-orbit="auto 110deg 160%"
                  interaction-prompt="none"
                  touch-action="pan-y"
                ></model-viewer>
                <span class="vh-pdp-3d-hint vh-mono">360° · Sleep om te draaien</span>
              </>
            )}
          </div>
          {(product.images.length > 1 || product.model) && (
            <div class="vh-pdp-thumbs" id="vh-pdp-thumbs">
              {product.model && (
                <button type="button" class="vh-pdp-thumb vh-pdp-thumb--3d is-active" data-3d aria-label="360 graden weergave">
                  <span class="vh-mono">360°</span>
                </button>
              )}
              {product.images.map((img, i) => (
                <button type="button" class={`vh-pdp-thumb${i === 0 && !product.model ? ' is-active' : ''}`} data-img={optimizedSrc(img, 1080)} data-full={optimizedSrc(img, 1920)} aria-label={`Foto ${i + 1}`}>
                  <Pic src={img} alt="" width={72} height={90} widths={[160]} sizes="72px" loading="lazy" />
                </button>
              ))}
            </div>
          )}
        </div>

        <!-- Info -->
        <div class="vh-pdp-info">
          <p class="vh-pdp-kicker vh-mono">Heritage collectie · Genummerde oplage</p>
          <h1 class="vh-pdp-title">{product.name}</h1>
          <p class="vh-pdp-color">{product.color}</p>

          <p class="vh-pdp-price">
            {product.compare_at_cents && <del>{formatPrice(product.compare_at_cents)}</del>}
            <span class="vh-pdp-price-now">{formatPrice(product.price_cents)}</span>
            {savingsCents > 0 && (
              <span class="vh-pdp-save">−{savingsPct}% · je bespaart {formatPrice(savingsCents)}</span>
            )}
          </p>
          <p class="vh-pdp-short">{product.short_desc}</p>

          {edition && !soldOut && (
            <div class="vh-pdp-scarcity">
              <div class="vh-pdp-scarcity-head">
                <span class="vh-mono">Genummerde oplage</span>
                <span class="vh-mono"><b>{totalStock}</b> van {edition} over</span>
              </div>
              <div class="vh-pdp-scarcity-bar" role="progressbar" aria-valuenow={editionPct} aria-valuemin="0" aria-valuemax="100">
                <span style={`width:${editionPct}%`}></span>
              </div>
              <p class="vh-pdp-scarcity-note">{soldOfEdition} al verkocht. Als deze {edition} op zijn, komen ze niet terug.</p>
            </div>
          )}

          <div class="vh-pdp-sizes-head">
            <span>Maat</span>
            <button type="button" class="vh-pdp-sizeguide-btn" id="vh-pdp-sizeguide-open">Maatgids ↗</button>
          </div>
          <div class="vh-pdp-sizes" id="vh-pdp-sizes" role="radiogroup" aria-label="Kies je maat">
            {product.variants.map((v) => (
              <button
                type="button"
                role="radio"
                aria-checked="false"
                class={`vh-size${v.stock === 0 ? ' is-out' : ''}`}
                data-variant={v.id}
                data-size={v.size}
                data-stock={v.stock}
              >{v.size}</button>
            ))}
          </div>
          <p class="vh-pdp-stockmsg" id="vh-pdp-stockmsg"></p>

          <!-- Back-in-stock (Zeigarnik + loss aversion): verschijnt bij uitverkochte maat -->
          <div class="vh-pdp-notify" id="vh-pdp-notify" hidden>
            <p class="vh-mono">Mail me als <b id="vh-pdp-notify-size">deze maat</b> terug is</p>
            <form id="vh-pdp-notify-form">
              <input type="email" required placeholder="jouw@email.nl" id="vh-pdp-notify-email" autocomplete="email" aria-label="E-mailadres voor voorraadmelding" />
              <button type="submit" class="vh-btn vh-btn--ghost"><span>Houd me op de hoogte</span></button>
            </form>
            <p class="vh-pdp-notify-done" id="vh-pdp-notify-done" hidden>Top, we mailen je zodra deze maat er weer is.</p>
          </div>

          <div class="vh-pdp-atc">
            <button type="button" class="vh-btn vh-btn--accent" id="vh-pdp-add" disabled={soldOut}>
              <span id="vh-pdp-add-label">{soldOut ? 'Uitverkocht' : 'Kies je maat'}</span>
            </button>
            <button type="button" class="vh-pdp-wish" id="vh-pdp-wish" aria-pressed="false">
              <span class="vh-pdp-wish-ico" aria-hidden="true">♡</span>
              <span class="vh-pdp-wish-label">Zet op verlanglijst</span>
            </button>
          </div>

          <!-- Bezorgdatum (onzekerheidsreductie): client-side berekend -->
          <p class="vh-pdp-delivery" id="vh-pdp-delivery" hidden>
            <i>✦</i> <span></span>
          </p>

          <div class="vh-pdp-trust">
            <span><i>✦</i> Gratis verzending in NL vanaf € 75</span>
            <span><i>✦</i> 30 dagen bedenktijd, retour gratis</span>
            <span><i>✦</i> Genummerd · geleverd met certificaat van echtheid</span>
            <span><i>✦</i> Veilig betalen via Mollie · iDEAL, Bancontact, creditcard</span>
          </div>

          <details class="vh-acc" open>
            <summary>Het verhaal</summary>
            <div class="vh-acc-body">{product.description}</div>
          </details>
          <details class="vh-acc">
            <summary>Details &amp; materiaal</summary>
            <div class="vh-acc-body">
              <ul>{product.details.map((d) => <li>{d}</li>)}</ul>
            </div>
          </details>
          <details class="vh-acc">
            <summary>Verzending &amp; retour</summary>
            <div class="vh-acc-body">
              Voor 16:00 besteld, binnen 2 werkdagen in huis. Verzending via PostNL.
              Niet goed? Retourneren kan kosteloos binnen 30 dagen.
            </div>
          </details>

          <div class="vh-pdp-faq">
            <p class="vh-pdp-faq-head vh-mono">Veelgestelde vragen</p>
            {faqItems.map((f) => (
              <details class="vh-acc">
                <summary>{f.q}</summary>
                <div class="vh-acc-body">{f.a}</div>
              </details>
            ))}
          </div>
        </div>
      </div>

      <!-- Reviews (sociaal bewijs): eerlijke staat, echte input -->
      <section class="vh-reviews" id="vh-reviews" aria-label="Reviews">
        <div class="vh-reviews-head">
          <div>
            <p class="vh-mono">Wat dragers zeggen</p>
            <h2>Reviews</h2>
          </div>
          <div class="vh-reviews-agg" id="vh-reviews-agg"></div>
        </div>
        <div class="vh-reviews-list" id="vh-reviews-list"></div>
        <button type="button" class="vh-btn vh-btn--ghost vh-reviews-toggle" id="vh-reviews-toggle"><span>Schrijf een review</span></button>
        <form class="vh-reviews-form" id="vh-reviews-form" hidden>
          <div class="vh-reviews-field">
            <label for="vh-rev-name">Je naam</label>
            <input type="text" id="vh-rev-name" required maxlength="40" placeholder="Bv. Sanne uit Tilburg" />
          </div>
          <div class="vh-reviews-field">
            <span class="vh-reviews-label">Jouw beoordeling</span>
            <div class="vh-reviews-stars-input" id="vh-rev-stars" role="radiogroup" aria-label="Aantal sterren">
              {[1, 2, 3, 4, 5].map((n) => (
                <button type="button" class="vh-rev-star" data-val={n} aria-label={`${n} ster${n > 1 ? 'ren' : ''}`}>★</button>
              ))}
            </div>
          </div>
          <div class="vh-reviews-field">
            <label for="vh-rev-text">Je ervaring</label>
            <textarea id="vh-rev-text" rows="3" required maxlength="500" placeholder="Hoe zit het, hoe voelt het, zou je het aanraden?"></textarea>
          </div>
          <button type="submit" class="vh-btn vh-btn--accent"><span>Plaats review</span></button>
          <p class="vh-reviews-note vh-mono" id="vh-reviews-note">Demo: reviews worden lokaal in je browser bewaard tot de database live staat.</p>
        </form>
      </section>

      <div class="vh-pdp-related vh-recent" id="vh-recent" hidden>
        <h2>Onlangs <span class="vh-italic-accent">bekeken</span></h2>
        <div class="vh-listing" id="vh-recent-list"></div>
      </div>

      {related.length > 0 && (
        <div class="vh-pdp-related">
          <h2>Ook uit het <span class="vh-italic-accent">archief</span></h2>
          <div class="vh-listing">
            {related.map((p, i) => (
              <a href={`/shop/${p.slug}`} class="vh-card">
                <div class="vh-card-media">
                  <span class="vh-card-num">0{i + 1}</span>
                  {p.badge && <span class="vh-card-badge">{p.badge}</span>}
                  <Pic src={p.images[0]} alt={p.name} class="vh-card-img main" width={600} height={750} loading="lazy" />
                  {p.images[1] && <Pic src={p.images[1]} alt="" class="vh-card-img alt" width={600} height={750} loading="lazy" aria-hidden="true" />}
                </div>
                <div class="vh-card-info">
                  <p class="vh-card-name">{p.name}</p>
                  <p class="vh-card-price">{formatPrice(p.price_cents)}</p>
                </div>
                <p class="vh-card-meta">{p.meta}</p>
              </a>
            ))}
          </div>
        </div>
      )}

    </div>
  </section>

  <!-- Maatgids modal -->
  <div class="vh-modal" id="vh-sizeguide" hidden>
    <div class="vh-modal-backdrop" data-sizeguide-close></div>
    <div class="vh-modal-panel" role="dialog" aria-modal="true" aria-labelledby="vh-sizeguide-title">
      <button type="button" class="vh-modal-close" data-sizeguide-close aria-label="Sluiten">✕</button>
      <p class="vh-mono">Villa Happ · Maatgids</p>
      <h3 id="vh-sizeguide-title">Vind jouw maat</h3>
      {sizeType === 'apparel' && (
        <>
          <table class="vh-sizetable">
            <thead><tr><th>Maat</th><th>Lengte (cm)</th><th>Borst (cm)</th></tr></thead>
            <tbody>
              {apparelRows.map((r) => <tr><td>{r.size}</td><td>{r.len}</td><td>{r.chest}</td></tr>)}
            </tbody>
          </table>
          <p class="vh-sizeguide-tip">Onze stukken vallen ruim en unisex. Twijfel je tussen twee maten? Kies de kleinere voor een strakkere pasvorm.</p>
        </>
      )}
      {sizeType === 'socks' && (
        <>
          <table class="vh-sizetable">
            <thead><tr><th>Maat</th><th>Schoenmaat (EU)</th></tr></thead>
            <tbody><tr><td>36/41</td><td>36 t/m 41</td></tr><tr><td>42/46</td><td>42 t/m 46</td></tr></tbody>
          </table>
          <p class="vh-sizeguide-tip">Kies je sokmaat op basis van je gewone schoenmaat.</p>
        </>
      )}
      {sizeType === 'onesize' && (
        <p class="vh-sizeguide-tip">One size, verstelbaar via de clipsluiting achter. Past comfortabel op een hoofdomtrek van circa 54 tot 61 cm.</p>
      )}
    </div>
  </div>

  <!-- Lightbox: hoofdbeeld op groot formaat, klik om in te zoomen -->
  <div class="vh-lightbox" id="vh-lightbox" hidden>
    <button type="button" class="vh-lightbox-close" id="vh-lightbox-close" aria-label="Sluiten">✕</button>
    <div class="vh-lightbox-stage" id="vh-lightbox-stage" role="dialog" aria-modal="true" aria-label={`${product.name} op groot formaat`}>
      <img id="vh-lightbox-img" src="" alt={`${product.name} ${product.color}, groot formaat`} />
    </div>
    <p class="vh-lightbox-hint vh-mono">Klik op de foto om in te zoomen · Esc om te sluiten</p>
  </div>

  <!-- Sticky mobile add-to-cart -->
  <div class="vh-pdp-sticky" id="vh-pdp-sticky">
    <b>{formatPrice(product.price_cents)}</b>
    <button type="button" class="vh-btn vh-btn--accent" id="vh-pdp-add-sticky" disabled={soldOut}>
      <span>{soldOut ? 'Uitverkocht' : 'In winkelmandje'}</span>
    </button>
  </div>

  <style>
    .vh-lightbox {
      position: fixed;
      inset: 0;
      z-index: 9500;
      background: rgba(20, 19, 17, 0.94);
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
    }
    .vh-lightbox[hidden] { display: none; }
    .vh-lightbox-stage {
      width: 100%;
      height: 100%;
      display: flex;
      align-items: center;
      justify-content: center;
      overflow: hidden;
    }
    .vh-lightbox-stage img {
      max-width: min(92vw, 1100px);
      max-height: 88vh;
      object-fit: contain;
      cursor: zoom-in;
      transition: transform 0.35s cubic-bezier(0.22, 1, 0.36, 1);
    }
    .vh-lightbox-stage img.is-zoomed {
      transform: scale(2.2);
      cursor: zoom-out;
    }
    .vh-lightbox-close {
      position: absolute;
      top: 18px;
      right: 20px;
      z-index: 2;
      width: 44px;
      height: 44px;
      border-radius: 999px;
      border: 1px solid rgba(247, 243, 236, 0.35);
      background: transparent;
      color: #f7f3ec;
      font-size: 16px;
      cursor: pointer;
    }
    .vh-lightbox-close:hover { background: rgba(247, 243, 236, 0.12); }
    .vh-lightbox-hint {
      position: absolute;
      bottom: 18px;
      left: 50%;
      transform: translateX(-50%);
      color: rgba(247, 243, 236, 0.65);
      font-size: 11px;
      pointer-events: none;
    }
    @media (max-width: 700px) {
      .vh-lightbox-hint { display: none; }
    }
  </style>

  <script type="application/json" id="vh-pdp-data" set:html={JSON.stringify(pdpData)}></script>

  <!-- SEO: structured data voor rich results -->
  <script type="application/ld+json" set:html={JSON.stringify(productLd)} is:inline></script>
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbLd)} is:inline></script>
  <script type="application/ld+json" set:html={JSON.stringify(faqLd)} is:inline></script>

</Base>

<script>
  import { addToCart, openCart } from '../../lib/cart';
  import { toggleWishlist, inWishlist } from '../../lib/wishlist';
  import { recordRecent, getRecent } from '../../lib/recent';
  import { flyToCart } from '../../lib/fx';

  const data = JSON.parse(document.getElementById('vh-pdp-data')!.textContent!);

  /* 3D-viewer alleen laden op producten met een model (eigen bundle,
     code-split; geen Google CDN meer) */
  if (data.model) import('@google/model-viewer');

  /* Gallery thumbs: foto's wisselen, 360°-knop schakelt de 3D-viewer in */
  const mainImg = document.getElementById('vh-pdp-mainimg') as HTMLImageElement;
  const mainBox = document.getElementById('vh-pdp-main')!;
  let currentFull: string = data.image_full;
  document.querySelectorAll<HTMLButtonElement>('.vh-pdp-thumb').forEach((thumb) => {
    thumb.addEventListener('click', () => {
      document.querySelectorAll('.vh-pdp-thumb').forEach((t) => t.classList.remove('is-active'));
      thumb.classList.add('is-active');
      if (thumb.hasAttribute('data-3d')) {
        mainBox.classList.add('show-3d');
        return;
      }
      mainBox.classList.remove('show-3d');
      if (thumb.dataset.full) currentFull = thumb.dataset.full;
      mainImg.style.opacity = '0';
      setTimeout(() => {
        // srcset weg: anders blijft de browser het oude responsive beeld kiezen
        mainImg.removeAttribute('srcset');
        mainImg.src = thumb.dataset.img!;
        mainImg.style.opacity = '1';
      }, 180);
    });
  });

  /* Lightbox: hoofdbeeld groot bekijken + inzoomen op klikpunt */
  (function lightbox() {
    const box = document.getElementById('vh-lightbox')!;
    const img = document.getElementById('vh-lightbox-img') as HTMLImageElement;
    const stage = document.getElementById('vh-lightbox-stage')!;
    const closeBtn = document.getElementById('vh-lightbox-close')!;
    let lastFocus: HTMLElement | null = null;

    const open = () => {
      lastFocus = document.activeElement as HTMLElement;
      img.src = currentFull;
      img.classList.remove('is-zoomed');
      box.removeAttribute('hidden');
      document.body.style.overflow = 'hidden';
      (closeBtn as HTMLElement).focus();
    };
    const close = () => {
      box.setAttribute('hidden', '');
      document.body.style.overflow = '';
      lastFocus?.focus();
    };

    mainImg.style.cursor = 'zoom-in';
    mainImg.addEventListener('click', () => {
      if (mainBox.classList.contains('show-3d')) return;
      open();
    });
    closeBtn.addEventListener('click', close);
    stage.addEventListener('click', (e) => {
      if (e.target !== img) { close(); return; }
      // Zoom in of uit op het aangeklikte punt
      const zoomed = img.classList.toggle('is-zoomed');
      if (zoomed) {
        const r = img.getBoundingClientRect();
        img.style.transformOrigin = `${(((e as MouseEvent).clientX - r.left) / r.width) * 100}% ${(((e as MouseEvent).clientY - r.top) / r.height) * 100}%`;
      }
    });
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && !box.hasAttribute('hidden')) close();
    });
  })();

  /* Maatselectie + back-in-stock */
  let selected: { id: string; size: string; stock: number } | null = null;
  const addBtn = document.getElementById('vh-pdp-add') as HTMLButtonElement;
  const addLabel = document.getElementById('vh-pdp-add-label')!;
  const stickyBtn = document.getElementById('vh-pdp-add-sticky') as HTMLButtonElement | null;
  const stockMsg = document.getElementById('vh-pdp-stockmsg')!;
  const notify = document.getElementById('vh-pdp-notify')!;
  const notifySize = document.getElementById('vh-pdp-notify-size')!;

  document.querySelectorAll<HTMLButtonElement>('.vh-size').forEach((btn) => {
    btn.addEventListener('click', () => {
      const isOut = btn.classList.contains('is-out');
      document.querySelectorAll('.vh-size').forEach((b) => {
        b.classList.remove('is-active');
        b.setAttribute('aria-checked', 'false');
      });
      btn.classList.add('is-active');
      btn.setAttribute('aria-checked', 'true');

      if (isOut) {
        // Uitverkochte maat: bied een voorraadmelding aan i.p.v. toevoegen
        selected = null;
        addBtn.disabled = true;
        addLabel.textContent = 'Uitverkocht in deze maat';
        stockMsg.textContent = '';
        notifySize.textContent = `maat ${btn.dataset.size}`;
        notify.removeAttribute('hidden');
        return;
      }

      notify.setAttribute('hidden', '');
      selected = { id: btn.dataset.variant!, size: btn.dataset.size!, stock: parseInt(btn.dataset.stock!, 10) };
      addBtn.disabled = false;
      addLabel.textContent = 'In winkelmandje';
      stockMsg.textContent = selected.stock <= 3 ? `Nog ${selected.stock} op voorraad in deze maat` : '';
    });
  });

  /* Pijltjestoetsen binnen de maat-radiogroup (verwacht gedrag bij role=radio) */
  const sizeGroup = document.getElementById('vh-pdp-sizes');
  sizeGroup?.addEventListener('keydown', (e) => {
    if (!['ArrowRight', 'ArrowDown', 'ArrowLeft', 'ArrowUp'].includes(e.key)) return;
    const btns = Array.from(sizeGroup.querySelectorAll<HTMLButtonElement>('.vh-size'));
    const idx = btns.indexOf(document.activeElement as HTMLButtonElement);
    if (idx === -1) return;
    e.preventDefault();
    const dir = e.key === 'ArrowRight' || e.key === 'ArrowDown' ? 1 : -1;
    const next = btns[(idx + dir + btns.length) % btns.length];
    next.focus();
    next.click();
  });

  function add(e?: Event) {
    if (!selected) {
      stockMsg.textContent = 'Kies eerst een maat';
      document.getElementById('vh-pdp-sizes')?.scrollIntoView({ behavior: 'smooth', block: 'center' });
      return;
    }
    addToCart({
      variant_id: selected.id,
      product_id: data.slug,
      quantity: 1,
      name: `${data.name}`,
      variant_label: `${data.color} / ${selected.size}`,
      unit_price_cents: data.price_cents,
      image_url: data.image,
      slug: data.slug,
    });
    // Vlieg-naar-mandje vanaf de geklikte knop, dan pas de drawer openen
    const btn = (e?.currentTarget as HTMLElement) || addBtn;
    const r = btn.getBoundingClientRect();
    flyToCart(data.image, r.left + r.width / 2, r.top + r.height / 2);
    window.dispatchEvent(new CustomEvent('vh:toast', { detail: 'Toegevoegd aan je mandje ✦' }));
    setTimeout(() => openCart(), 520);
  }

  addBtn.addEventListener('click', add);
  stickyBtn?.addEventListener('click', add);

  /* Onlangs bekeken vastleggen (mere-exposure) */
  recordRecent({ slug: data.slug, name: data.name, price_cents: data.price_cents, image_url: data.image });

  /* Verlanglijst-knop */
  const wishBtn = document.getElementById('vh-pdp-wish');
  if (wishBtn) {
    const ico = wishBtn.querySelector('.vh-pdp-wish-ico')!;
    const lbl = wishBtn.querySelector('.vh-pdp-wish-label')!;
    const sync = (on: boolean) => {
      wishBtn.classList.toggle('is-on', on);
      wishBtn.setAttribute('aria-pressed', String(on));
      ico.textContent = on ? '♥' : '♡';
      lbl.textContent = on ? 'Bewaard op verlanglijst' : 'Zet op verlanglijst';
    };
    sync(inWishlist(data.slug));
    wishBtn.addEventListener('click', () => {
      const on = toggleWishlist({ slug: data.slug, name: data.name, price_cents: data.price_cents, image_url: data.image, color: data.color });
      sync(on);
      window.dispatchEvent(new CustomEvent('vh:toast', { detail: on ? 'Bewaard op je verlanglijst ✦' : 'Verwijderd van verlanglijst' }));
    });
  }

  /* Onlangs bekeken rail (huidige product uitgesloten) */
  (function renderRecent() {
    const box = document.getElementById('vh-recent');
    const list = document.getElementById('vh-recent-list');
    if (!box || !list) return;
    const items = getRecent().filter((r) => r.slug !== data.slug).slice(0, 4);
    if (!items.length) return;
    const eur = (c: number) => '€ ' + (c / 100).toFixed(2).replace('.', ',');
    list.innerHTML = items.map((r) => `
      <a href="/shop/${r.slug}" class="vh-card">
        <div class="vh-card-media vh-skeleton">
          <img src="${r.image_url}" alt="${r.name}" class="vh-card-img" width="600" height="750" loading="lazy" style="opacity:0;transition:opacity .4s ease" onload="this.style.opacity=1;this.parentElement.classList.remove('vh-skeleton')" />
        </div>
        <div class="vh-card-info"><p class="vh-card-name">${r.name}</p><p class="vh-card-price">${eur(r.price_cents)}</p></div>
      </a>`).join('');
    box.removeAttribute('hidden');
  })();

  /* Back-in-stock formulier: naar de database, lokaal als demo-fallback */
  const notifyForm = document.getElementById('vh-pdp-notify-form') as HTMLFormElement;
  const notifyEmail = document.getElementById('vh-pdp-notify-email') as HTMLInputElement;
  const notifyDone = document.getElementById('vh-pdp-notify-done')!;
  notifyForm?.addEventListener('submit', async (e) => {
    e.preventDefault();
    if (!notifyEmail.value || !/.+@.+\..+/.test(notifyEmail.value)) { notifyEmail.focus(); return; }
    const size = (notifySize.textContent || '').replace(/^maat\s+/i, '');
    let saved = false;
    try {
      const res = await fetch('/api/notify', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ slug: data.slug, size, email: notifyEmail.value }),
      });
      saved = res.ok;
    } catch {}
    if (!saved) {
      try {
        const key = 'vh_backinstock';
        const list = JSON.parse(localStorage.getItem(key) || '[]');
        list.push({ slug: data.slug, size, email: notifyEmail.value });
        localStorage.setItem(key, JSON.stringify(list));
      } catch {}
    }
    notifyForm.setAttribute('hidden', '');
    notifyDone.removeAttribute('hidden');
  });

  /* Sticky bar: toon wanneer hoofdknop uit beeld is */
  const sticky = document.getElementById('vh-pdp-sticky');
  if (sticky && 'IntersectionObserver' in window) {
    const obs = new IntersectionObserver((entries) => {
      entries.forEach((e) => sticky.classList.toggle('is-visible', !e.isIntersecting));
    }, { threshold: 0 });
    obs.observe(addBtn);
  }

  /* Live voorraad: de geprerenderde aantallen verversen bij bezoek.
     Zonder database (503) blijven de gebakken demo-waarden gewoon staan. */
  (async function liveStock() {
    try {
      const res = await fetch(`/api/stock?slug=${encodeURIComponent(data.slug)}`);
      if (!res.ok) return;
      const json = await res.json();
      const stockById: Record<string, number> = {};
      (json.variants || []).forEach((v: { id: string; stock: number }) => { stockById[v.id] = v.stock; });
      if (!Object.keys(stockById).length) return;

      let total = 0;
      document.querySelectorAll<HTMLButtonElement>('.vh-size').forEach((btn) => {
        const id = btn.dataset.variant!;
        if (!(id in stockById)) return;
        const stock = stockById[id];
        total += stock;
        btn.dataset.stock = String(stock);
        btn.classList.toggle('is-out', stock === 0);
      });

      // Geselecteerde maat opnieuw valideren tegen de actuele stand
      if (selected && selected.id in stockById) {
        const cur = stockById[selected.id];
        if (cur === 0) {
          // Alsnog uitverkocht: dezelfde flow als een klik op een uitverkochte maat
          document.querySelector<HTMLButtonElement>(`.vh-size[data-variant="${selected.id}"]`)?.click();
        } else {
          selected.stock = cur;
          stockMsg.textContent = cur <= 3 ? `Nog ${cur} op voorraad in deze maat` : '';
        }
      }

      // Schaarste-balk bijwerken (alleen bij een genummerde oplage)
      if (data.edition) {
        const sold = Math.max(0, data.edition - total);
        const pct = Math.min(100, Math.round((sold / data.edition) * 100));
        const headCount = document.querySelector('.vh-pdp-scarcity-head b');
        const bar = document.querySelector<HTMLElement>('.vh-pdp-scarcity-bar span');
        const barBox = document.querySelector('.vh-pdp-scarcity-bar');
        const note = document.querySelector('.vh-pdp-scarcity-note');
        if (headCount) headCount.textContent = String(total);
        if (bar) bar.style.width = `${pct}%`;
        barBox?.setAttribute('aria-valuenow', String(pct));
        if (note) note.textContent = `${sold} al verkocht. Als deze ${data.edition} op zijn, komen ze niet terug.`;
      }

      // Volledig uitverkocht geraakt sinds de build
      if (total === 0) {
        selected = null;
        addBtn.disabled = true;
        addLabel.textContent = 'Uitverkocht';
        if (stickyBtn) {
          stickyBtn.disabled = true;
          const lbl = stickyBtn.querySelector('span');
          if (lbl) lbl.textContent = 'Uitverkocht';
        }
      }
    } catch { /* netwerkfout: gebakken waarden blijven staan */ }
  })();

  /* Bezorgdatum (onzekerheidsreductie): voor 16:00 = volgende werkdag verzonden */
  (function deliveryEstimate() {
    const box = document.getElementById('vh-pdp-delivery');
    const span = box?.querySelector('span');
    if (!box || !span) return;
    const days = ['zondag', 'maandag', 'dinsdag', 'woensdag', 'donderdag', 'vrijdag', 'zaterdag'];
    const months = ['jan', 'feb', 'mrt', 'apr', 'mei', 'jun', 'jul', 'aug', 'sep', 'okt', 'nov', 'dec'];
    const nextBiz = (d: Date) => { do { d.setDate(d.getDate() + 1); } while (d.getDay() === 0 || d.getDay() === 6); return d; };
    const now = new Date();
    let ship = new Date(now);
    if (now.getHours() >= 16) ship = nextBiz(ship);
    while (ship.getDay() === 0 || ship.getDay() === 6) ship = nextBiz(ship);
    const deliver = nextBiz(ship);
    const beforeCutoff = now.getHours() < 16 && now.getDay() !== 0 && now.getDay() !== 6;
    const label = `${beforeCutoff ? 'Vandaag voor 16:00 besteld' : 'Nu besteld'} → ${days[deliver.getDay()]} ${deliver.getDate()} ${months[deliver.getMonth()]} in huis`;
    span.textContent = label;
    box.removeAttribute('hidden');
  })();

  /* Maatgids modal (met focus trap: Tab blijft binnen de dialoog) */
  (function sizeGuide() {
    const modal = document.getElementById('vh-sizeguide');
    const openBtn = document.getElementById('vh-pdp-sizeguide-open');
    if (!modal || !openBtn) return;
    let lastFocus: HTMLElement | null = null;
    const focusables = () =>
      Array.from(modal.querySelectorAll<HTMLElement>('button, [href], input, select, textarea, [tabindex]:not([tabindex="-1"])'))
        .filter((el) => el.offsetParent !== null);
    const open = () => {
      lastFocus = document.activeElement as HTMLElement;
      modal.removeAttribute('hidden');
      document.body.style.overflow = 'hidden';
      focusables()[0]?.focus();
    };
    const close = () => {
      modal.setAttribute('hidden', '');
      document.body.style.overflow = '';
      lastFocus?.focus();
    };
    openBtn.addEventListener('click', open);
    modal.querySelectorAll('[data-sizeguide-close]').forEach((el) => el.addEventListener('click', close));
    document.addEventListener('keydown', (e) => { if (e.key === 'Escape' && !modal.hasAttribute('hidden')) close(); });
    modal.addEventListener('keydown', (e) => {
      if (e.key !== 'Tab') return;
      const els = focusables();
      if (!els.length) return;
      const first = els[0];
      const last = els[els.length - 1];
      if (e.shiftKey && document.activeElement === first) { e.preventDefault(); last.focus(); }
      else if (!e.shiftKey && document.activeElement === last) { e.preventDefault(); first.focus(); }
    });
  })();

  /* Reviews (sociaal bewijs): database-first met moderatie; zonder DB
     valt alles terug op het lokale demo-gedrag */
  (function reviews() {
    const KEY = `vh_reviews_${data.slug}`;
    const aggEl = document.getElementById('vh-reviews-agg')!;
    const listEl = document.getElementById('vh-reviews-list')!;
    const toggle = document.getElementById('vh-reviews-toggle')!;
    const form = document.getElementById('vh-reviews-form') as HTMLFormElement;
    const note = document.getElementById('vh-reviews-note')!;
    const starsInput = document.getElementById('vh-rev-stars')!;
    const nameEl = document.getElementById('vh-rev-name') as HTMLInputElement;
    const textEl = document.getElementById('vh-rev-text') as HTMLTextAreaElement;
    let rating = 0;
    let serverMode = false;

    type Review = { name: string; rating: number; text: string; date: string };

    const loadLocal = (): Review[] => { try { return JSON.parse(localStorage.getItem(KEY) || '[]'); } catch { return []; } };
    const stars = (n: number) => '★★★★★☆☆☆☆☆'.slice(5 - Math.round(n), 10 - Math.round(n));
    function esc(s: string) { const d = document.createElement('div'); d.textContent = s; return d.innerHTML; }

    function render(all: Review[]) {
      if (!all.length) {
        aggEl.innerHTML = '<span class="vh-reviews-empty">Nog geen reviews. Wees de eerste die dit stuk beoordeelt.</span>';
        listEl.innerHTML = '';
        return;
      }
      const avg = all.reduce((s, r) => s + r.rating, 0) / all.length;
      aggEl.innerHTML = `<span class="vh-reviews-stars">${stars(avg)}</span><span class="vh-reviews-score">${avg.toFixed(1)}</span><span class="vh-reviews-count">${all.length} review${all.length > 1 ? 's' : ''}</span>`;
      listEl.innerHTML = all.map((r) =>
        `<article class="vh-review"><div class="vh-review-top"><span class="vh-reviews-stars">${stars(r.rating)}</span><b>${esc(r.name)}</b><time>${esc(r.date)}</time></div><p>${esc(r.text)}</p></article>`
      ).join('');
    }

    const fmtDate = (iso: string) => {
      const d = new Date(iso);
      return isNaN(d.valueOf()) ? '' : `${d.getDate()}-${d.getMonth() + 1}-${d.getFullYear()}`;
    };

    async function init() {
      try {
        const res = await fetch(`/api/reviews?slug=${encodeURIComponent(data.slug)}`);
        if (res.ok) {
          const json = await res.json();
          serverMode = true;
          note.setAttribute('hidden', '');
          render((json.reviews || []).map((r: any) => ({
            name: r.name, rating: r.rating, text: r.body, date: fmtDate(r.created_at),
          })));
          return;
        }
      } catch {}
      // Demo-fallback: lokaal bewaarde reviews (nieuwste eerst)
      render(loadLocal().slice().reverse());
    }

    starsInput.querySelectorAll<HTMLButtonElement>('.vh-rev-star').forEach((b) => {
      b.addEventListener('click', () => {
        rating = parseInt(b.dataset.val!, 10);
        starsInput.querySelectorAll('.vh-rev-star').forEach((s, i) => s.classList.toggle('is-on', i < rating));
      });
    });

    toggle.addEventListener('click', () => {
      const open = form.hasAttribute('hidden');
      if (open) { form.removeAttribute('hidden'); nameEl.focus(); } else { form.setAttribute('hidden', ''); }
    });

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      if (!rating) { starsInput.classList.add('is-error'); return; }
      starsInput.classList.remove('is-error');
      const review = { name: nameEl.value.trim() || 'Anoniem', rating, text: textEl.value.trim() };

      let toastMsg = 'Bedankt voor je review ✦';
      if (serverMode) {
        try {
          const res = await fetch('/api/reviews', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ slug: data.slug, ...review }),
          });
          if (!res.ok) throw new Error();
          toastMsg = 'Bedankt! Je review verschijnt na een korte controle ✦';
        } catch {
          toastMsg = 'Opslaan lukte niet, probeer het later opnieuw';
        }
      } else {
        const d = new Date();
        const all = loadLocal();
        all.push({ ...review, date: `${d.getDate()}-${d.getMonth() + 1}-${d.getFullYear()}` });
        try { localStorage.setItem(KEY, JSON.stringify(all)); } catch {}
        render(all.slice().reverse());
      }

      form.reset();
      rating = 0;
      starsInput.querySelectorAll('.vh-rev-star').forEach((s) => s.classList.remove('is-on'));
      form.setAttribute('hidden', '');
      window.dispatchEvent(new CustomEvent('vh:toast', { detail: toastMsg }));
    });

    init();
  })();
</script>
