---
// Statisch gebouwd op deploy-moment: instant vanaf Vercel's CDN.
// (Zodra Supabase live data nodig is per request, schakel om naar ISR.)
export const prerender = true;

import Base from '../layouts/Base.astro';
import Loader from '../components/home/Loader.astro';
import Hero from '../components/home/Hero.astro';
import Marquee from '../components/home/Marquee.astro';
import Manifesto from '../components/home/Manifesto.astro';
import YearMask from '../components/home/YearMask.astro';
import HeritageScroll from '../components/home/HeritageScroll.astro';
import Campaign from '../components/home/Campaign.astro';
import DropSpotlight from '../components/home/DropSpotlight.astro';
import ParallaxColumns from '../components/home/ParallaxColumns.astro';
import ShopGrid from '../components/home/ShopGrid.astro';
import Lookbook from '../components/home/Lookbook.astro';
import KineticWordmark from '../components/home/KineticWordmark.astro';
import Brands from '../components/home/Brands.astro';
import Finale from '../components/home/Finale.astro';

import '../styles/home.css';
---

<Base bodyClass="vh-home" title="Villa Happ · Heritage lifestyle, gemaakt voor nu" preloadImage="/img/products/hoodie-grey-lifestyle-v2.webp">
  <Loader />
  <Hero />
  <Marquee />
  <Manifesto />
  <YearMask />
  <HeritageScroll />
  <Campaign />
  <DropSpotlight />
  <ShopGrid />
  <ParallaxColumns />
  <Lookbook />
  <KineticWordmark />
  <Brands />
  <Finale />
</Base>

<script>
  document.body.setAttribute('data-page', 'home');
</script>

<script>
  import '../lib/motion';
  import '../lib/cart';
</script>
