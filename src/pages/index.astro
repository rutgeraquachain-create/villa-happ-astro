---
import Base from '../layouts/Base.astro';
import Loader from '../components/home/Loader.astro';
import Hero from '../components/home/Hero.astro';
import Marquee from '../components/home/Marquee.astro';
import Manifesto from '../components/home/Manifesto.astro';
import HeritageScroll from '../components/home/HeritageScroll.astro';
import DropSpotlight from '../components/home/DropSpotlight.astro';
import ShopGrid from '../components/home/ShopGrid.astro';
import Lookbook from '../components/home/Lookbook.astro';
import Brands from '../components/home/Brands.astro';
import NewsletterCTA from '../components/home/NewsletterCTA.astro';

import '../styles/home.css';
---

<Base bodyClass="vh-home" title="Villa Happ — Heritage lifestyle, gemaakt voor nu">
  <Loader />
  <Hero />
  <Marquee />
  <Manifesto />
  <HeritageScroll />
  <DropSpotlight />
  <ShopGrid />
  <Lookbook />
  <Brands />
  <NewsletterCTA />
</Base>

<script>
  document.body.setAttribute('data-page', 'home');
</script>

<script>
  import '../lib/motion';
  import '../lib/cart';
</script>
