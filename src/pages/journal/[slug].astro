---
export const prerender = true;

import { getCollection, render } from 'astro:content';
import type { CollectionEntry } from 'astro:content';
import Base from '../../layouts/Base.astro';
import Pic from '../../components/Pic.astro';
import { stewardLd } from '../../lib/entity';
import '../../styles/shop.css';

export async function getStaticPaths() {
  const posts = await getCollection('journal');
  return posts.map((post) => ({ params: { slug: post.id }, props: { post } }));
}

interface Props { post: CollectionEntry<'journal'> }
const { post } = Astro.props;
const { Content } = await render(post);

const fmt = (d: Date) =>
  d.toLocaleDateString('nl-NL', { day: 'numeric', month: 'long', year: 'numeric' });

const siteOrigin = Astro.site?.origin || Astro.url.origin;
const postUrl = `${siteOrigin}/journal/${post.id}`;

const articleLd = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: post.data.title,
  description: post.data.description,
  datePublished: post.data.date.toISOString(),
  dateModified: post.data.date.toISOString(),
  image: post.data.image ? [siteOrigin + post.data.image] : undefined,
  url: postUrl,
  mainEntityOfPage: postUrl,
  inLanguage: 'nl-NL',
  // Person-auteur (Rutger van Happen) i.p.v. de organisatie: sterker
  // E-E-A-T-signaal en een citeerbaar entiteitsanker voor AI-engines.
  author: stewardLd(siteOrigin),
  publisher: { '@id': `${siteOrigin}/#organization` },
};

const breadcrumbLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: `${siteOrigin}/` },
    { '@type': 'ListItem', position: 2, name: 'Journal', item: `${siteOrigin}/journal` },
    { '@type': 'ListItem', position: 3, name: post.data.title, item: postUrl },
  ],
};
---
<Base title={`${post.data.title} · Villa Happ`} description={post.data.description} ogImage={post.data.image}>
  <section class="vh-page">
    <div class="vh-page-inner vh-article-inner">

      <nav class="vh-breadcrumb" aria-label="Kruimelpad">
        <a href="/">Home</a> <span aria-hidden="true">/</span>
        <a href="/journal">Journal</a> <span aria-hidden="true">/</span>
        <span class="vh-breadcrumb-current">{post.data.title}</span>
      </nav>

      <article class="vh-article">
        <header class="vh-article-head">
          <p class="vh-mono vh-article-date">{fmt(post.data.date)}</p>
          <h1>{post.data.title}</h1>
          <p class="vh-article-lede">{post.data.description}</p>
        </header>

        {post.data.image && (
          <div class="vh-article-hero">
            <Pic
              src={post.data.image}
              alt={post.data.imageAlt || post.data.title}
              width={1080}
              height={720}
              widths={[480, 768, 1080]}
              sizes="(max-width: 900px) 100vw, 760px"
              loading="eager"
              fetchpriority="high"
            />
          </div>
        )}

        <div class="vh-article-body">
          <Content />
        </div>

        <footer class="vh-article-foot">
          <a href="/journal" class="vh-btn vh-btn--ghost"><span>← Alle verhalen</span></a>
          <a href="/shop" class="vh-btn vh-btn--accent"><span>Shop de collectie</span></a>
        </footer>
      </article>

    </div>
  </section>

  <style>
    .vh-article-inner { max-width: 820px; }
    .vh-article-head { text-align: center; margin-bottom: 30px; }
    .vh-article-date { font-size: 11px; opacity: 0.55; }
    .vh-article-head h1 {
      font-family: var(--vh-font-serif);
      font-size: clamp(30px, 4.4vw, 46px);
      line-height: 1.12;
      margin: 10px 0 14px;
    }
    .vh-article-lede { font-size: 16px; line-height: 1.7; opacity: 0.7; max-width: 56ch; margin: 0 auto; }
    .vh-article-hero { margin: 0 0 34px; }
    .vh-article-hero img { width: 100%; height: auto; }
    .vh-article-body { font-size: 16px; line-height: 1.8; }
    .vh-article-body :global(h2) {
      font-family: var(--vh-font-serif);
      font-size: 26px;
      margin: 36px 0 12px;
      line-height: 1.25;
    }
    .vh-article-body :global(p) { margin: 0 0 18px; }
    .vh-article-body :global(a) { color: inherit; text-underline-offset: 3px; }
    .vh-article-foot {
      display: flex;
      gap: 12px;
      justify-content: space-between;
      flex-wrap: wrap;
      margin-top: 42px;
      padding-top: 26px;
      border-top: 1px solid var(--vh-line, rgba(30, 30, 27, 0.14));
    }
  </style>

  <script type="application/ld+json" set:html={JSON.stringify(articleLd)} is:inline></script>
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbLd)} is:inline></script>
</Base>

<script>import '../../lib/cart';</script>
